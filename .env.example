# 이 파일은 self-hosted GitHub Actions 러너가 실행하는 deploy-with-notify.sh /
# deploy.sh가 참조하는 서버 로컬 설정입니다. GitHub Secrets가 아닙니다 — 이 값들은
# 서버 밖으로 나갈 필요가 없고, repository_dispatch 이벤트로도 전달되지 않습니다.

# --- 배포 대상 (deploy.sh가 참조) ---
# 절대경로를 코드에 하드코딩하지 않고 .env로 뺐다 — 서버 계정/경로가 바뀌어도
# 코드 수정 없이 .env만 갱신하면 된다.
PROJECT_DIR=/path/to/project
DOCKER_HOST=

# --- 알림 ---
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- 로그 마스킹 (deploy.sh 출력에 섞일 수 있는 값들, 있으면 채워둘 것) ---
POSTGRES_PASSWORD=
SESSION_SECRET=
ADMIN_PASSWORD_HASH=
