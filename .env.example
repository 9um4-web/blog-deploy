# --- 서버 실행 ---
PORT=25565 # minecraft?

# --- 배포 대상 (deploy.sh가 참조) ---
# 절대경로를 코드에 하드코딩하지 않고 .env로 뺐다 — 서버 계정/경로가 바뀌어도
# 코드 수정 없이 .env만 갱신하면 된다.
PROJECT_DIR=/path/to/project
DOCKER_HOST=

# --- 웹훅 인증 ---
# 서로 다른 값이어야 한다. 같은 값을 재사용하면 사실상 단일 인증이 된다.
WEBHOOK_HMAC_SECRET=
WEBHOOK_AUTH_TOKEN=
CUSTOM_AUTH_HEADER_NAME=

# 배포가 이 시간(ms)을 넘기면 죽은 락으로 간주하고 자동 해제
DEPLOY_TIMEOUT_MS=600000

# --- 인증 실패 레이트리밋 ---
# 윈도우(ms) 안에서 이 횟수만큼 인증 실패하면 해당 IP를 잠근다.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_FAILURES=10

# --- 알림 ---
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PROXY_HOST=

# --- 로그 마스킹 (deploy.sh 출력에 섞일 수 있는 값들, 있으면 채워둘 것) ---
POSTGRES_PASSWORD=
SESSION_SECRET=
ADMIN_PASSWORD_HASH=
